EDC_CATALOG_CACHE_EXECUTION_DELAY_SECONDS='10'
EDC_CATALOG_CACHE_EXECUTION_PERIOD_SECONDS='10'
EDC_DATASOURCE_DEFAULT_PASSWORD=${DB_PASSWORD}
EDC_DATASOURCE_DEFAULT_URL=jdbc:postgresql://postgres:5432/${PARTICIPANT}
EDC_DATASOURCE_DEFAULT_USER=${POSTGRES_USER}
EDC_DSP_CALLBACK_ADDRESS=${PUBLIC_CP_URL}/api/dsp
EDC_IAM_DID_WEB_USE_HTTPS='true'
EDC_IAM_ISSUER_ID=${DID}
EDC_IAM_STS_OAUTH_CLIENT_ID=${DID}
EDC_IAM_STS_OAUTH_CLIENT_SECRET_ALIAS=did:web:${BASE_URL}:${PARTICIPANT}-sts-client-secret
EDC_IAM_STS_OAUTH_TOKEN_URL=http://identity-hub:7084/api/sts/token
EDC_IAM_STS_PRIVATEKEY_ALIAS=${DID}#key-1
EDC_IAM_STS_PUBLICKEY_ID=${DID}#key-1
EDC_IH_AUDIENCE_REGISTRY_PATH=/etc/registry/registry.json
EDC_MVD_PARTICIPANTS_LIST_FILE=/etc/participants/participants.json
EDC_PARTICIPANT_ID=${DID}
EDC_SQL_SCHEMA_AUTOCREATE='true'
EDC_VAULT_HASHICORP_TOKEN=${VAULT_EDC_TOKEN}
EDC_VAULT_HASHICORP_URL=http://vault:8200
JAVA_TOOL_OPTIONS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:7066
WEB_HTTP_CATALOG_AUTH_KEY=${AUTH_KEY}
WEB_HTTP_CATALOG_AUTH_TYPE=tokenbased
WEB_HTTP_CATALOG_PATH=/api/catalog
WEB_HTTP_CATALOG_PORT=7064
WEB_HTTP_CONTROL_PATH=/api/control
WEB_HTTP_CONTROL_PORT=7063
WEB_HTTP_MANAGEMENT_AUTH_KEY=${AUTH_KEY}
WEB_HTTP_MANAGEMENT_AUTH_TYPE=tokenbased
WEB_HTTP_MANAGEMENT_PATH=/api/management
WEB_HTTP_MANAGEMENT_PORT=7061
WEB_HTTP_PATH=/api
WEB_HTTP_PORT=7060
WEB_HTTP_PROTOCOL_PATH=/api/dsp
WEB_HTTP_PROTOCOL_PORT=7062
WEB_HTTP_VERSION_PORT=7065
WEB_HTTP_VERSION_PATH=/api/version

EDC_IAM_TRUSTED-ISSUER_FLYPROVIDER_ID=${TRUSTED_ISSUER_DID}
EDC_IAM_TRUSTED-ISSUER_FLYPROVIDER_SUPPORTEDTYPES=["*"]
TX_EDC_VALIDATOR_CONTRACTDEFINITIONS_BLOCK_EMPTY_ASSET_SELECTOR='true'
EDC_IAM_CREDENTIAL_REVOCATION_MIMETYPE=application/json
