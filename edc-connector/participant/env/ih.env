EDC_DATASOURCE_DEFAULT_PASSWORD=${DB_PASSWORD}
EDC_DATASOURCE_DEFAULT_URL=jdbc:postgresql://postgres:5432/${PARTICIPANT}
EDC_DATASOURCE_DEFAULT_USER=${POSTGRES_USER}
EDC_IAM_ACCESSTOKEN_JTI_VALIDATION='true'
EDC_IAM_DID_WEB_USE_HTTPS='true'
EDC_IAM_STS_PRIVATEKEY_ALIAS=key-1
EDC_IAM_STS_PUBLICKEY_ID=key-1
EDC_IH_API_SUPERUSER_KEY=${IH_API_KEY}
EDC_IH_IAM_ID=${DID}
EDC_IH_IAM_PUBLICKEY_ALIAS=consumer-identityhub-publickey
EDC_MVD_CREDENTIALS_PATH=/etc/credentials/
EDC_SQL_SCHEMA_AUTOCREATE='true'
EDC_VAULT_HASHICORP_TOKEN=${VAULT_EDC_TOKEN}
EDC_VAULT_HASHICORP_URL=http://vault:8200
JAVA_TOOL_OPTIONS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:7085
WEB_HTTP_CREDENTIALS_PATH=/api/credentials
WEB_HTTP_CREDENTIALS_PORT=7082
WEB_HTTP_DID_PATH=/
WEB_HTTP_DID_PORT=7083
WEB_HTTP_IDENTITY_AUTH_KEY=${AUTH_KEY}
WEB_HTTP_IDENTITY_PATH=/api/identity
WEB_HTTP_IDENTITY_PORT=7081
WEB_HTTP_PATH=/api
WEB_HTTP_PORT=7080
WEB_HTTP_STS_PATH=/api/sts
WEB_HTTP_STS_PORT=7084
EDC_COMPONENT_ID=${PARTICIPANT}-identityhub
